{
    "$schema": "https://calm.finos.org/release/1.2/meta/calm.json",
    "$id": "https://example.com/patterns/service-with-messaging.pattern.json",
    "title": "Service with Messaging Pattern",
    "description": "A pattern for a service connected to a messaging service (RabbitMQ, Apache Kafka, or AWS SQS)",
    "type": "object",
    "properties": {
        "nodes": {
            "type": "array",
            "minItems": 2,
            "maxItems": 2,
            "prefixItems": [
                {
                    "$ref": "https://calm.finos.org/release/1.2/meta/core.json#/defs/node",
                    "type": "object",
                    "properties": {
                        "unique-id": { "const": "my-service" },
                        "name": { "const": "My Service" },
                        "node-type": { "const": "service" },
                        "description": { "const": "My Service" },
                        "interfaces": {
                            "type": "array",
                            "minItems": 1,
                            "maxItems": 1,
                            "prefixItems": [
                                {
                                    "$ref": "https://calm.finos.org/release/1.2/meta/interface.json#/defs/interface-type",
                                    "properties": {
                                        "unique-id": {
                                            "const": "my-interface"
                                        }
                                    }
                                }
                            ]
                        }
                    },
                    "required": ["description"]
                },
                {
                    "oneOf": [
                        {
                            "$ref": "https://calm.finos.org/release/1.2/meta/core.json#/defs/node",
                            "type": "object",
                            "properties": {
                                "unique-id": { "const": "rabbitmq-messaging-service" },
                                "name": { "const": "Messaging Service" },
                                "node-type": { "const": "service" },
                                "description": { "const": "RabbitMQ Messaging Service" },
                                "interfaces": {
                                    "type": "array",
                                    "minItems": 1,
                                    "maxItems": 1,
                                    "prefixItems": [
                                        {
                                            "$ref": "https://calm.finos.org/release/1.2/meta/interface.json#/defs/interface-type",
                                            "properties": {
                                                "unique-id": { "const": "rabbitmq-interface" },
                                                "host": { "type": "string" },
                                                "port": { "type": "string" },
                                                "virtual-host": { "type": "string" }
                                            }
                                        }
                                    ]
                                }
                            },
                            "required": ["description"]
                        },
                        {
                            "$ref": "https://calm.finos.org/release/1.2/meta/core.json#/defs/node",
                            "type": "object",
                            "properties": {
                                "unique-id": { "const": "kafka-messaging-service" },
                                "name": { "const": "Messaging Service" },
                                "node-type": { "const": "service" },
                                "description": { "const": "Apache Kafka Messaging Service" },
                                "interfaces": {
                                    "type": "array",
                                    "minItems": 1,
                                    "maxItems": 1,
                                    "prefixItems": [
                                        {
                                            "$ref": "https://calm.finos.org/release/1.2/meta/interface.json#/defs/interface-type",
                                            "properties": {
                                                "unique-id": { "const": "kafka-interface" },
                                                "bootstrap-servers": { "type": "string" },
                                                "topic": { "type": "string" }
                                            }
                                        }
                                    ]
                                }
                            },
                            "required": ["description"]
                        },
                        {
                            "$ref": "https://calm.finos.org/release/1.2/meta/core.json#/defs/node",
                            "type": "object",
                            "properties": {
                                "unique-id": { "const": "sqs-messaging-service" },
                                "name": { "const": "AWS SQS Messaging Service" },
                                "node-type": { "const": "service" },
                                "description": { "const": "AWS SQS Messaging Service" },
                                "interfaces": {
                                    "type": "array",
                                    "minItems": 1,
                                    "maxItems": 1,
                                    "prefixItems": [
                                        {
                                            "$ref": "https://calm.finos.org/release/1.2/meta/interface.json#/defs/interface-type",
                                            "properties": {
                                                "unique-id": { "const": "sqs-interface" },
                                                "queue-url": { "type": "string" },
                                                "region": { "type": "string" }
                                            }
                                        }
                                    ]
                                }
                            },
                            "required": ["description"]
                        }
                    ]
                }
            ]
        },
        "relationships": {
            "type": "array",
            "minItems": 2,
            "maxItems": 2,
            "prefixItems": [
                {
                    "$ref": "https://calm.finos.org/release/1.2/meta/core.json#/defs/relationship",
                    "type": "object",
                    "properties": {
                        "unique-id": { "const": "messaging-service-choice" },
                        "description": { "const": "Which messaging service should be used?" },
                        "relationship-type": {
                            "type": "object",
                            "properties": {
                                "options": {
                                    "type": "array",
                                    "prefixItems": [
                                        {
                                            "oneOf": [
                                                {
                                                    "$ref": "https://calm.finos.org/release/1.2/meta/core.json#/defs/decision",
                                                    "type": "object",
                                                    "properties": {
                                                        "description": { "const": "Use RabbitMQ" },
                                                        "nodes": { "const": ["rabbitmq-messaging-service"] },
                                                        "relationships": { "const": ["my-service-to-rabbitmq"] }
                                                    }
                                                },
                                                {
                                                    "$ref": "https://calm.finos.org/release/1.2/meta/core.json#/defs/decision",
                                                    "type": "object",
                                                    "properties": {
                                                        "description": { "const": "Use Apache Kafka" },
                                                        "nodes": { "const": ["kafka-messaging-service"] },
                                                        "relationships": { "const": ["my-service-to-kafka"] }
                                                    }
                                                },
                                                {
                                                    "$ref": "https://calm.finos.org/release/1.2/meta/core.json#/defs/decision",
                                                    "type": "object",
                                                    "properties": {
                                                        "description": { "const": "Use AWS SQS" },
                                                        "nodes": { "const": ["sqs-messaging-service"] },
                                                        "relationships": { "const": ["my-service-to-sqs"] }
                                                    }
                                                }
                                            ]
                                        }
                                    ]
                                }
                            }
                        }
                    }
                },
                {
                    "oneOf": [
                        {
                            "$ref": "https://calm.finos.org/release/1.2/meta/core.json#/defs/relationship",
                            "properties": {
                                "unique-id": { "const": "my-service-to-rabbitmq" },
                                "description": { "const": "My Service Using RabbitMQ" },
                                "relationship-type": {
                                    "const": {
                                        "connects": {
                                            "source": { "node": "my-service" },
                                            "destination": { "node": "rabbitmq-messaging-service" }
                                        }
                                    }
                                }
                            }
                        },{
                            "$ref": "https://calm.finos.org/release/1.2/meta/core.json#/defs/relationship",
                            "properties": {
                                "unique-id": { "const": "my-service-to-kafka" },
                                "description": { "const": "My Service Using Kafka" },
                                "relationship-type": {
                                    "const": {
                                        "connects": {
                                            "source": { "node": "my-service" },
                                            "destination": { "node": "kafka-messaging-service" }
                                        }
                                    }
                                }
                            }
                        },{
                            "$ref": "https://calm.finos.org/release/1.2/meta/core.json#/defs/relationship",
                            "properties": {
                                "unique-id": { "const": "my-service-to-sqs"},
                                "description": { "const": "My Service Using AWS SQS" },
                                "relationship-type": {
                                    "const": {
                                        "connects": {
                                            "source": { "node": "my-service" },
                                            "destination": { "node": "sqs-messaging-service" }
                                        }
                                    }
                                }
                            }
                        }
                    ]
                }        
            ]
        }
    },
    "required": ["nodes", "relationships"]
}