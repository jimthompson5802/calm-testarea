{
    "$schema": "https://calm.finos.org/release/1.2/meta/calm.json",
    "$id": "https://example.com/patterns/app-with-database.pattern.json",
    "title": "Application with Database Choice Pattern",
    "type": "object",
    "properties": {
        "nodes": {
            "type": "array",
            "minItems": 2,
            "maxItems": 2,
            "prefixItems": [
                {
                    "$ref": "https://calm.finos.org/release/1.2/meta/core.json#/defs/node",
                    "type": "object",
                    "properties": {
                        "unique-id": { "const": "application-service" },
                        "name": { "const": "Application Service" },
                        "node-type": { "const": "service" },
                        "description": { "type": "string" },
                        "interfaces": {
                            "type": "array",
                            "minItems": 1,
                            "maxItems": 1,
                            "prefixItems": [
                                {
                                    "$ref": "https://calm.finos.org/release/1.2/meta/interface.json#/defs/interface-type",
                                    "properties": {
                                        "unique-id": { "const": "app-api" },
                                        "host": { "type": "string" },
                                        "port": { "type": "integer" }
                                    }
                                }
                            ]
                        }
                    },
                    "required": ["description"]
                },
                {
                    "oneOf": [
                        {
                            "$ref": "https://calm.finos.org/release/1.2/meta/core.json#/defs/node",
                            "type": "object",
                            "properties": {
                                "unique-id": { "const": "mongodb-database" },
                                "name": { "const": "MongoDB Database" },
                                "node-type": { "const": "database" },
                                "description": { "const": "MongoDB NoSQL database" },
                                "interfaces": {
                                    "type": "array",
                                    "minItems": 1,
                                    "maxItems": 1,
                                    "prefixItems": [
                                        {
                                            "$ref": "https://calm.finos.org/release/1.2/meta/interface.json#/defs/interface-type",
                                            "properties": {
                                                "unique-id": { "const": "mongodb-connection" },
                                                "host": { "type": "string" },
                                                "port": { "const": 27017 }
                                            }
                                        }
                                    ]
                                }
                            }
                        },
                        {
                            "$ref": "https://calm.finos.org/release/1.2/meta/core.json#/defs/node",
                            "type": "object",
                            "properties": {
                                "unique-id": { "const": "mysql-database" },
                                "name": { "const": "MySQL Database" },
                                "node-type": { "const": "database" },
                                "description": { "const": "MySQL relational database" },
                                "interfaces": {
                                    "type": "array",
                                    "minItems": 1,
                                    "maxItems": 1,
                                    "prefixItems": [
                                        {
                                            "$ref": "https://calm.finos.org/release/1.2/meta/interface.json#/defs/interface-type",
                                            "properties": {
                                                "unique-id": { "const": "mysql-connection" },
                                                "host": { "type": "string" },
                                                "port": { "const": 3306 }
                                            }
                                        }
                                    ]
                                }
                            }
                        }
                    ]
                }
            ]
        },
        "relationships": {
            "type": "array",
            "minItems": 2,
            "maxItems": 2,
            "prefixItems": [
                {
                    "$ref": "https://calm.finos.org/release/1.2/meta/core.json#/defs/relationship",
                    "type": "object",
                    "properties": {
                        "unique-id": { "const": "database-choice" },
                        "description": { "const": "Which database should the application use?" },
                        "relationship-type": {
                            "type": "object",
                            "properties": {
                                "options": {
                                    "type": "array",
                                    "prefixItems": [
                                        {
                                            "oneOf": [
                                                {
                                                    "$ref": "https://calm.finos.org/release/1.2/meta/core.json#/defs/decision",
                                                    "type": "object",
                                                    "properties": {
                                                        "description": { "const": "Use MongoDB" },
                                                        "nodes": { 
                                                            "const": ["mongodb-database"] 
                                                        },
                                                        "relationships": { 
                                                            "const": ["app-to-mongodb"] 
                                                        }
                                                    }
                                                },
                                                {
                                                    "$ref": "https://calm.finos.org/release/1.2/meta/core.json#/defs/decision",
                                                    "type": "object",
                                                    "properties": {
                                                        "description": { "const": "Use MySQL" },
                                                        "nodes": { 
                                                            "const": ["mysql-database"] 
                                                        },
                                                        "relationships": { 
                                                            "const": ["app-to-mysql"] 
                                                        }
                                                    }
                                                }
                                            ]
                                        }
                                    ]
                                }
                            }
                        }
                    }
                },
                {
                    "oneOf": [
                        {
                            "$ref": "https://calm.finos.org/release/1.2/meta/core.json#/defs/relationship",
                            "type": "object",
                            "properties": {
                                "unique-id": { "const": "app-to-mongodb" },
                                "description": { "const": "Application connects to MongoDB database" },
                                "protocol": { "const": "TCP" },
                                "relationship-type": {
                                    "const": {
                                        "connects": {
                                            "source": { "node": "application-service" },
                                            "destination": { "node": "mongodb-database" }
                                        }
                                    }
                                }
                            }
                        },
                        {
                            "$ref": "https://calm.finos.org/release/1.2/meta/core.json#/defs/relationship",
                            "type": "object",
                            "properties": {
                                "unique-id": { "const": "app-to-mysql" },
                                "description": { "const": "Application connects to MySQL database" },
                                "protocol": { "const": "JDBC" },
                                "relationship-type": {
                                    "const": {
                                        "connects": {
                                            "source": { "node": "application-service" },
                                            "destination": { "node": "mysql-database" }
                                        }
                                    }
                                }
                            }
                        }
                    ]
                }
            ]
        }
    }
}